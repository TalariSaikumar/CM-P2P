# Server
HTTP_PORT=8080
GIN_MODE=debug

# Database (Azure Postgres)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_HOURS=72

# Demo only: allow POST /api/me/complete-kyc to mark users verified (disable in production)
ALLOW_SELF_KYC_VERIFY=false

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# Twilio (later: notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
