# Required: which YAML file under config/ to load (without .yaml)
APP_ENV=dev

# Optional — put secrets here (backend/.env is gitignored), not in config/*.yaml
# DATABASE_URL=postgres://user:pass@localhost:5432/carmanage?sslmode=disable
# JWT_SECRET=your-long-random-secret
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_STORAGE_CONTAINER=
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CORS_ALLOW_VERCEL=false
