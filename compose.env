# Variables for docker-compose.yml (${...} substitution).
# Option A — copy to ".env" in the repo root (Compose loads it automatically):
#   cp compose.env .env
# Option B — pass this file explicitly:
#   docker compose --env-file compose.env up --build
#
# Paths are relative to the directory that contains docker-compose.yml.
#
# APP_ENV must match APP_ENV inside backend/.env and picks backend/config/{APP_ENV}.yaml
# for the image build (same as the API at runtime).

BACKEND_ENV_PATH=./backend/.env
BACKEND_CONFIG_DIR=./backend/config
HOST_PORT=8080
APP_ENV=stag
