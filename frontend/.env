# Tracked default env for the web app. Use `.env.local` for secrets/overrides (not committed).
#
# Environment flavour: dev | stag | prod — loads frontend/config/{APP_ENV}.yaml (next.config.mjs).
APP_ENV=dev

# Optional overrides (otherwise taken from config/{APP_ENV}.yaml):
