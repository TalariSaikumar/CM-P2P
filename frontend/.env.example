# Copy to Vercel → Project → Settings → Environment Variables
# (or use .env.local locally — do not commit secrets)

# Use stag or prod on Vercel (loads frontend/config/{APP_ENV}.yaml when vars below are unset)
APP_ENV=stag

# Required on Vercel — your public Go API URL (must include /api)
NEXT_PUBLIC_API_URL=https://your-backend-host.example.com/api

# Optional
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourcompany.com
